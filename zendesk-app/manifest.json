{
  "name": "AI Ticket Copilot",
  "author": {
    "name": "Your Team",
    "email": "support@example.com",
    "url": "https://example.com"
  },
  "defaultLocale": "en",
  "private": true,
  "version": "0.1.0",
  "frameworkVersion": "2.0",
  "location": {
    "support": {
      "ticket_sidebar": {
        "url": "assets/iframe.html",
        "flexible": true,
        "size": {
          "height": "720px"
        }
      }
    }
  },
  "domainWhitelist": ["{{setting.backend_domain}}"],
  "parameters": [
    {
      "name": "backend_origin",
      "type": "text",
      "required": true
    },
    {
      "name": "backend_domain",
      "type": "text",
      "required": true
    },
    {
      "name": "backend_api_key",
      "type": "text",
      "required": true,
      "secure": true,
      "scopes": ["header"]
    }
  ]
}

